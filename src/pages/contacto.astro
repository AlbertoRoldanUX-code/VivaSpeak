<Layout
  title="Oficinas VivaSpeak en España | Contacto por Provincia"
  description="Encuentra la oficina VivaSpeak más cercana. Presencia en todas las provincias de España. Contacta con nuestro equipo de agentes IA para automatizar tu negocio."
  canonical="https://vivaspeak.com/contacto/"
  alternateEs="https://vivaspeak.com/contacto/"
  lang="es"
  robots="index, follow"
  speakable={['.contacto-hero h1', '.contacto-hero p']}
>
  <LandingHeader ctaLabel="Solicitar demo" ctaHref="/#schedule" secondaryHref="/" />

  <main id="main-content">
    <section class="contacto-hero">
      <div class="container">
        <p class="eyebrow">Oficinas VivaSpeak</p>
        <h1>Estamos en toda España</h1>
        <p class="contacto-hero__sub">
          Encuentra tu oficina más cercana y habla con nuestro equipo. Automatiza llamadas, WhatsApp
          y atención al cliente con IA.
        </p>
      </div>
    </section>

    <section class="oficinas-section">
      <div class="container">
        {
          offices.map((office, i) => (
            <article
              class={`oficina-card ${i % 2 === 0 ? 'oficina-card--left' : 'oficina-card--right'}`}
              id={office.city.toLowerCase().replace(/\s+/g, '-')}
            >
              <div class="oficina-card__info">
                <div class="oficina-card__heading">
                  <span class="oficina-label">Oficina</span>
                  <h2>{office.city}</h2>
                </div>
                <div class="oficina-card__details">
                  <p class="oficina-card__name">{office.coworking}</p>
                  <p class="oficina-card__address">
                    {office.address}
                    <br />
                    {office.city}, {office.zip}
                  </p>
                  <p class="oficina-card__phone">
                    T <a href="tel:+34951798932">(+34) 951 798 932</a>
                  </p>
                  <p class="oficina-card__whatsapp">
                    <img
                      src="https://cdn.jsdelivr.net/npm/simple-icons@v10/icons/whatsapp.svg"
                      alt=""
                      width="16"
                      height="16"
                      class="oficina-icon"
                    />
                    <a href="https://wa.me/34951798932" target="_blank" rel="noopener noreferrer">
                      Hablemos por WhatsApp
                    </a>
                  </p>
                  <p class="oficina-card__email">
                    <a href="mailto:alberto@vivaspeak.com">alberto@vivaspeak.com</a>
                  </p>
                  <a href="/#schedule" class="btn-oficina">
                    Contáctanos
                  </a>
                </div>
              </div>
              <div class="oficina-card__map">
                <iframe
                  src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=${encodeURIComponent(office.coworking.startsWith('[') ? office.city + ', Spain' : office.coworking + ', ' + office.address + ', ' + office.city + ', Spain')}&zoom=15`}
                  width="100%"
                  height="350"
                  style="border:0; border-radius: 16px;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Mapa de la oficina VivaSpeak en ${office.city}`}
                />
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="contacto-cta">
      <div class="container">
        <h2>¿No encuentras tu ciudad?</h2>
        <p>Llámanos o escríbenos y te atendemos desde cualquier punto de España.</p>
        <div class="cta-buttons">
          <a href="tel:+34951798932" class="btn-primary">Llamar ahora</a>
          <a href="/#schedule" class="btn-secondary">Reservar reunión</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* Hero */
  .contacto-hero {
    padding: 120px 2rem 60px;
    background: linear-gradient(to bottom, #f5fafa, #e9f2f2);
    text-align: center;
  }
  .contacto-hero h1 {
    font-size: 2.8rem;
    font-weight: 800;
    background: linear-gradient(120deg, var(--color-dark), var(--primary-dark));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin: 0 0 16px;
  }
  .contacto-hero__sub {
    font-size: 1.15rem;
    color: var(--color-text);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Offices section */
  .oficinas-section {
    padding: 60px 2rem 80px;
    background: var(--white);
  }
  .oficinas-section .container {
    max-width: 1100px;
  }

  /* Office card */
  .oficina-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding: 50px 0;
    border-bottom: 1px solid var(--gray-light);
  }
  .oficina-card:last-child {
    border-bottom: none;
  }
  .oficina-card--right {
    direction: rtl;
  }
  .oficina-card--right > * {
    direction: ltr;
  }

  /* Info side */
  .oficina-card__info {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .oficina-card__heading {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .oficina-label {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-dark);
    letter-spacing: 0.02em;
  }
  .oficina-card__heading h2 {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--primary-dark);
    margin: 0;
    text-align: left;
    line-height: 1.1;
  }

  /* Details card */
  .oficina-card__details {
    background: var(--white-2);
    border: 1px solid var(--gray-light);
    border-radius: 16px;
    padding: 24px 28px;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }
  .oficina-card__details::after {
    content: '';
    position: absolute;
    top: -30px;
    right: -30px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: rgba(26, 188, 156, 0.12);
    pointer-events: none;
  }
  .oficina-card__name {
    font-weight: 700;
    color: var(--color-dark);
    margin: 0 0 4px;
    font-size: 1.05rem;
  }
  .oficina-card__address {
    color: var(--gray-medium);
    margin: 0 0 14px;
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .oficina-card__phone {
    margin: 0 0 8px;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .oficina-card__phone a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
  }
  .oficina-card__whatsapp {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0 0 8px;
    font-size: 0.95rem;
  }
  .oficina-card__whatsapp a {
    color: #25d366;
    font-weight: 600;
    text-decoration: none;
  }
  .oficina-icon {
    filter: invert(55%) sepia(76%) saturate(520%) hue-rotate(107deg) brightness(95%) contrast(92%);
  }
  .oficina-card__email {
    margin: 0 0 18px;
    font-size: 0.95rem;
  }
  .oficina-card__email a {
    color: var(--color-text);
    text-decoration: none;
  }

  /* CTA button */
  .btn-oficina {
    display: inline-block;
    padding: 12px 28px;
    background: var(--primary-dark);
    color: var(--white);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 8px;
    text-decoration: none;
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }
  .btn-oficina:hover {
    background: var(--primary-darker);
    transform: scale(1.02);
  }

  /* Map */
  .oficina-card__map {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .oficina-card__map iframe {
    display: block;
    width: 100%;
    min-height: 350px;
  }

  /* Bottom CTA */
  .contacto-cta {
    padding: 80px 2rem;
    text-align: center;
    background: linear-gradient(to bottom, var(--white), #f4fffc);
  }
  .contacto-cta h2 {
    color: var(--primary-dark);
    margin-bottom: 12px;
  }
  .contacto-cta p {
    color: var(--color-text);
    margin-bottom: 28px;
    font-size: 1.1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .oficina-card {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 36px 0;
    }
    .oficina-card--right {
      direction: ltr;
    }
    .contacto-hero h1 {
      font-size: 2rem;
    }
    .oficina-card__heading h2 {
      font-size: 1.7rem;
    }
  }
</style>
