---
import Layout from '../layouts/Layout.astro';
import LandingHeader from '../components/LandingHeader.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { offices } from '../data/offices';
---

<Layout
  title="Oficinas VivaSpeak en España | Contacto por Provincia"
  description="Encuentra la oficina VivaSpeak más cercana. Presencia en todas las provincias de España. Contacta con nuestro equipo de agentes IA para automatizar tu negocio."
  canonical="https://vivaspeak.com/contacto/"
  alternateEs="https://vivaspeak.com/contacto/"
  lang="es"
  robots="index, follow"
  speakable={['.hero-content h1', '.hero-content .hero-subtitle']}
>
  <LandingHeader ctaLabel="Solicitar demo" ctaHref="/#schedule" secondaryHref="/" />

  <main id="main-content">
    <section class="hero hero--centered">
      <div class="container">
        <div class="hero-content">
          <span class="eyebrow">Oficinas VivaSpeak</span>
          <h1>Estamos en toda España</h1>
          <p class="hero-subtitle">
            Encuentra tu oficina más cercana y habla con nuestro equipo. Automatiza llamadas,
            WhatsApp y atención al cliente con IA.
          </p>
        </div>
      </div>
    </section>

    <section class="section oficinas-section">
      <div class="container">
        {
          offices.map((office) => (
            <article class="oficina-card" id={office.city.toLowerCase().replace(/\s+/g, '-')}>
              <div class="oficina-card__info">
                <h2 class="oficina-card__city">
                  <a href={`/ubicaciones/${office.slug}/`}>{office.city}</a>
                </h2>
                <div class="card oficina-card__details">
                  <p class="oficina-card__name">{office.coworking}</p>
                  <p class="oficina-card__address">
                    {office.address}
                    <br />
                    {office.city}, {office.zip}
                  </p>
                  <div class="oficina-card__contact">
                    <p>
                      <Icon name="phone" size={16} />
                      <a href="tel:+34951798932">(+34) 951 798 932</a>
                    </p>
                    <p>
                      <Icon name="whatsapp" size={16} class="icon-whatsapp" />
                      <a href="https://wa.me/34951795151" target="_blank" rel="noopener noreferrer">
                        Hablemos por WhatsApp
                      </a>
                    </p>
                    <p>
                      <Icon name="envelope" size={16} />
                      <a href="mailto:info@vivaspeak.com">info@vivaspeak.com</a>
                    </p>
                  </div>
                  <a href="/#schedule" class="btn btn-primary oficina-card__cta">
                    Contáctanos
                  </a>
                  <a href={`/ubicaciones/${office.slug}/`} class="oficina-card__link">
                    Ver más sobre {office.city} →
                  </a>
                </div>
              </div>
              <div class="oficina-card__map">
                <iframe
                  src={`https://www.google.com/maps/embed/v1/place?key=AIzaSyBgMyxkvnrslZQTcdCJAAs-8xE8gKeftkQ&q=${encodeURIComponent(office.coworking.startsWith('[') ? office.city + ', Spain' : office.coworking + ', ' + office.address + ', ' + office.city + ', Spain')}&zoom=15`}
                  width="100%"
                  height="350"
                  style="border:0; border-radius: var(--radius-lg);"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title={`Mapa de la oficina VivaSpeak en ${office.city}`}
                />
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main></Layout
>

<section class="section contacto-cta">
  <div class="container">
    <div class="section-header text-center">
      <h2>¿No encuentras tu ciudad?</h2>
      <p>Llámanos o escríbenos y te atendemos desde cualquier punto de España.</p>
    </div>
    <div class="cta-buttons">
      <a href="tel:+34951798932" class="btn btn-primary">Llamar ahora</a>
      <a href="/#schedule" class="btn btn-secondary">Reservar reunión</a>
    </div>
  </div>
</section>

<Footer />

<style>
  /* Offices section */
  .oficinas-section .container {
    max-width: 1060px;
  }

  /* Office card */
  .oficina-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-12) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .oficina-card:last-child {
    border-bottom: none;
  }

  /* Info side */
  .oficina-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-items: center;
    text-align: center;
  }

  /* City name */
  .oficina-card__city {
    font-size: var(--text-3xl);
    font-weight: var(--font-extrabold);
    color: var(--primary-dark);
    margin: 0;
    line-height: var(--leading-tight);
  }
  .oficina-card__city a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }
  .oficina-card__city a:hover {
    color: var(--primary);
  }

  /* Details card — extends .card */
  .oficina-card__details {
    text-align: center;
    width: 100%;
  }
  .oficina-card__name {
    font-weight: var(--font-bold);
    color: var(--gray-900);
    margin: 0 0 var(--space-1);
    font-size: var(--text-lg);
  }
  .oficina-card__address {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-5);
    line-height: var(--leading-normal);
    font-size: var(--text-sm);
  }

  /* Contact lines */
  .oficina-card__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  .oficina-card__contact p {
    margin: 0;
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }
  .oficina-card__contact i {
    color: var(--primary-dark);
    font-size: var(--text-sm);
    width: 16px;
    text-align: center;
  }
  .oficina-card__contact a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--font-medium);
    transition: color var(--transition-fast);
  }
  .oficina-card__contact a:hover {
    color: var(--primary-dark);
  }

  /* WhatsApp icon override */
  .oficina-card__contact .icon-whatsapp {
    color: #25d366;
  }

  /* CTA button */
  .oficina-card__cta {
    width: 100%;
    margin-bottom: var(--space-3);
  }

  /* Ver más link */
  .oficina-card__link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--primary-dark);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .oficina-card__link:hover {
    color: var(--primary);
  }

  /* Map */
  .oficina-card__map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--color-border);
  }
  .oficina-card__map iframe {
    display: block;
    width: 100%;
    min-height: 300px;
  }

  /* Bottom CTA */
  .cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  /* Desktop: two-column office cards */
  @media (min-width: 768px) {
    .oficina-card {
      grid-template-columns: 1fr 1.2fr;
      gap: var(--space-12);
    }
    .oficina-card:nth-child(even) {
      direction: rtl;
    }
    .oficina-card:nth-child(even) > * {
      direction: ltr;
    }
    .oficina-card__details {
      max-width: 380px;
    }
    .oficina-card__cta {
      width: auto;
    }
    .oficina-card__map iframe {
      min-height: 380px;
    }
  }
</style>
