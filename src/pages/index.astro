---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schemaFaq = [
  {
    question: '¿Qué es exactamente VivaSpeak?',
    answer:
      'Un sistema de automatización de negocios, que se especializa en la comunicación por voz y WhatsApp. Para responder dudas usamos la información del negocio que es editable desde nuestro panel. Nuestros agentes se especializan en cualificar leads.',
  },
  {
    question: '¿Cómo se estructura el precio?',
    answer:
      'El precio se define por agente según volumen, sector e integraciones. Te damos un único plan operativo sin desglose técnico.',
  },
  {
    question: '¿Se integra con mis herramientas?',
    answer:
      'Sí. Conectamos Google Calendar, HubSpot, CRMs propios y agendas con API, además de la API oficial de WhatsApp. Incluimos guías de desvío y de compartición de calendario.',
  },
  {
    question: '¿Puedo probarlo antes de contratarlo?',
    answer:
      'Cada agente incluye un piloto de una semana con tus flujos reales y KPIs compartidos en el panel.',
  },
  {
    question: '¿Qué idiomas cubre?',
    answer:
      'Los agentes suelen usar un idioma principal y le podemos añadir hasta 3 adicionales, entre ellos se encuentran español, inglés, portugués, francés, italiano y alemán. Pregunta por otros idiomas o acentos antes del lanzamiento.',
  },
  {
    question: '¿Puede el agente de voz IA transferir la llamada a una persona?',
    answer:
      'Sí, se puede programar que por ejemplo en caso de urgencia o filtrado positivo se transfiera la llamada a la persona adecuada.',
  },
];

const schemaHowTo = {
  name: 'Cómo funciona VivaSpeak',
  description: 'Tu agente IA atiende, cualifica y agenda sin fricción en 6 pasos.',
  step: [
    {
      name: 'Un cliente llama o escribe por WhatsApp',
      text: 'La IA responde al instante con voz natural.',
    },
    {
      name: 'La IA cualifica y responde preguntas',
      text: 'Accede a tu base de conocimiento para resolver dudas reales.',
    },
    {
      name: 'Agenda una cita en tu calendario real',
      text: 'Conecta con Google Calendar, CRM o agenda interna.',
    },
    {
      name: 'Tu equipo recibe un resumen automático',
      text: 'Email o WhatsApp con la conversación y la siguiente acción.',
    },
    {
      name: 'Consulta todos los leads en un panel siempre disponible',
      text: 'Un CRM visual donde puedes ver, filtrar y gestionar todos los contactos de un vistazo.',
    },
    {
      name: 'Llama o envía mensajes desde el panel sin salir del sistema',
      text: 'Activa seguimientos, responde contactos y lanza llamadas o mensajes sin salir del panel.',
    },
  ],
};

const schemaVideos = [
  {
    name: 'Demo Clara VivaSpeak - Agente de voz IA para clínicas',
    description:
      'Ejemplo real donde Clara atiende una llamada, resuelve dudas sobre tratamientos y agenda una cita automáticamente.',
    thumbnailUrl: 'https://img.youtube.com/vi/_MwMo-mlBGQ/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=_MwMo-mlBGQ',
    embedUrl: 'https://www.youtube.com/embed/_MwMo-mlBGQ',
  },
  {
    name: 'Testimonio de Daniel Insa - Agente inmobiliario',
    description:
      'Daniel Insa, agente inmobiliario RE/MAX en Málaga, explica cómo VivaSpeak le ayuda a atender más clientes sin interrumpir su trabajo.',
    thumbnailUrl: 'https://img.youtube.com/vi/vmtha03C92E/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=vmtha03C92E',
    embedUrl: 'https://www.youtube.com/embed/vmtha03C92E',
  },
];

const schemaReviews = [
  {
    author: 'Daniel Insa',
    role: 'Agente inmobiliario RE/MAX · Málaga',
    body: 'Gracias a Laura, puedo atender a más clientes sin interrumpir mi trabajo. Ella responde llamadas, filtra consultas y agenda visitas en mi calendario.',
    rating: 5,
  },
  {
    author: 'Reinaldo Rodríguez',
    role: 'Director de AllGrass · Madrid',
    body: 'Gracias a VivaSpeak optimizamos la gestión de llamadas para prestar un mejor servicio. Rebeca atiende en 4 idiomas y nos envía un email tras cada conversación. Ha sido una inversión que se ha pagado sola.',
    rating: 5,
  },
  {
    author: 'Juan Taborda',
    role: 'Villas y Fincas Mallorca · 20 años en el sector',
    body: 'Ahora atendemos 24h los 7 días, no perdemos contactos y precualificamos en una fracción del tiempo, incluso en picos de demanda. Funciona muy bien, está muy pulido.',
    rating: 5,
  },
  {
    author: 'Arturo Chavarría',
    role: 'MyCantabria Inmobiliaria · Cantabria',
    body: 'El servicio es muy funcional y suficiente para una inmobiliaria pequeña o mediana, especialmente para gestionar los contactos que no puedes atender cuando estás realizando otras funciones. Sin lugar a dudas, volvería a contratar con VivaSpeak en el futuro.',
    rating: 5,
  },
];
---

<Layout
  title="Agentes de IA para Llamadas y WhatsApp 24/7 | VivaSpeak"
  description="No pierdas más llamadas ni leads: un agente IA responde, cualifica y agenda por ti 24/7 en llamadas, WhatsApp y formularios."
  canonical="https://vivaspeak.com/"
  alternateEs="https://vivaspeak.com/"
  alternateEn="https://vivaspeak.com/en/"
  ogImage="https://vivaspeak.com/assets/og-image.png"
  ogType="website"
  lang="es"
  schemaFaq={schemaFaq}
  schemaHowTo={schemaHowTo}
  schemaVideos={schemaVideos}
  schemaReviews={schemaReviews}
  speakable={[
    '.home-title',
    '.home-description',
    '.faq-content',
    '.value-card p',
    '.results-card p',
  ]}
>
  <Header />
  <main id="main-content">
    <section id="home">
      <div class="container home-container">
        <div class="hero-bg-accent hero-bg-accent-one"></div>
        <div class="hero-bg-accent hero-bg-accent-two"></div>
        <div class="hero-grid">
          <div class="hero-left">
            <h1 class="home-title">
              Atiende llamadas, WhatsApp y filtra leads automáticamente 24/7
            </h1>
            <p class="home-description">
              Agenda citas, cualifica contactos y usa nuestro CRM o actualiza el tuyo sin
              interrumpir tu trabajo
            </p>
            <p class="home-urgency">
              Tus clientes no esperan. Si no respondes en segundos, llaman al siguiente.
            </p>
            <div class="cta-buttons">
              <a
                href="#schedule"
                class="btn-primary"
                data-ga-event="hero_try_agent_click"
                data-ga-location="hero"
              >
                Reserva reunión
              </a>
              <a
                href="#video-demo"
                class="btn-secondary"
                data-ga-event="hero_demo_click"
                data-ga-location="hero"
              >
                <i class="fa-solid fa-play"></i> Ver cómo funciona
              </a>
            </div>
            <div class="hero-trust">
              <div class="hero-stats">
                <div class="hero-stat">
                  <strong>&lt; 2 s</strong>
                  <span>tiempo medio de respuesta</span>
                </div>
                <div class="hero-stat">
                  <strong>24/7</strong>
                  <span>atención automática</span>
                </div>
                <div class="hero-stat">
                  <strong>0</strong>
                  <span>llamadas perdidas</span>
                </div>
              </div>
            </div>
          </div>
          <div class="hero-right">
            <div class="hero-mockup">
              <picture>
                <source srcset="/assets/whatsapp-mockup.webp" type="image/webp" />
                <img
                  src="/assets/whatsapp-mockup.webp"
                  alt="Conversación de un agente VivaSpeak en WhatsApp"
                  class="clickable-image"
                  fetchpriority="high"
                  loading="eager"
                />
              </picture>
              <div class="mockup-overlay">
                <div class="mockup-counter">
                  <span id="mockupCounter">+1 cita confirmada</span>
                </div>
                <div class="mockup-check">
                  <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                </div>
                <div class="mockup-toast" role="status" aria-live="polite">
                  <span class="mockup-toast__label">Nueva cita creada</span>
                  <span class="mockup-toast__time">· 16:00</span>
                  <span class="mockup-toast__name">Silvia Pérez</span>
                </div>
              </div>
            </div>
            <div class="hero-floating-card">
              <i class="fa-solid fa-robot"></i>
              <div>
                <p class="card-label">Agente Laura</p>
                <p class="card-value">Confirma una cita en 42s</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <div id="imageModal" class="modal" role="dialog" aria-modal="true" aria-label="Vista ampliada">
      <span class="close" aria-label="Cerrar">&times;</span>
      <img
        class="modal-content"
        id="modalImg"
        alt="Visual ampliada de la conversación de un agente VivaSpeak en WhatsApp"
      />
    </div>
    <section id="value-prop" class="value-summary">
      <div class="container">
        <p class="eyebrow">Cómo funciona VivaSpeak</p>
        <h2>Tu agente IA atiende, cualifica y agenda sin fricción</h2>
        <div class="value-grid">
          <article class="value-card">
            <span class="value-step">1</span>
            <h3>Un cliente llama o escribe por WhatsApp</h3>
            <p>La IA responde al instante con voz natural.</p>
          </article>
          <article class="value-card">
            <span class="value-step">2</span>
            <h3>La IA cualifica y responde preguntas</h3>
            <p>Accede a tu base de conocimiento para resolver dudas reales.</p>
          </article>
          <article class="value-card">
            <span class="value-step">3</span>
            <h3>Agenda una cita en tu calendario real</h3>
            <p>Conecta con Google Calendar, CRM o agenda interna.</p>
          </article>
          <article class="value-card">
            <span class="value-step">4</span>
            <h3>Tu equipo recibe un resumen automático</h3>
            <p>Email o WhatsApp con la conversación y la siguiente acción.</p>
          </article>
          <article class="value-card value-card--panel">
            <span class="value-step">5</span>
            <h3>Consulta todos los leads en un panel siempre disponible</h3>
            <p>
              Un CRM visual donde puedes ver, filtrar y gestionar todos los contactos de un vistazo.
            </p>
          </article>
          <article class="value-card">
            <span class="value-step">6</span>
            <h3>Llama o envía mensajes desde el panel sin salir del sistema</h3>
            <p>
              Activa seguimientos, responde contactos y lanza llamadas o mensajes sin salir del
              panel.
            </p>
          </article>
        </div>
      </div>
    </section>
    <section id="use-cases" class="results">
      <div class="container">
        <div class="section-header section-header--center">
          <p class="eyebrow">Qué problemas resuelve VivaSpeak</p>
          <h2>Los puntos donde más se te escapan llamadas, citas y leads</h2>
        </div>
        <div class="results-grid">
          <article class="results-card">
            <h3>No puedes atender llamadas mientras trabajas</h3>
            <p>El agente atiende, filtra y agenda por ti sin cortar tu operación.</p>
          </article>
          <article class="results-card">
            <h3>Te escriben fuera de horario</h3>
            <p>Responde WhatsApp automáticamente y deja la conversación encarrilada.</p>
          </article>
          <article class="results-card">
            <h3>Pierdes leads de formularios</h3>
            <p>La IA llama o responde al instante antes de que el lead se enfríe.</p>
          </article>
          <article class="results-card">
            <h3>Recibes demasiadas consultas repetidas</h3>
            <p>La IA contesta preguntas frecuentes y solo escala lo importante.</p>
          </article>
        </div>
      </div>
    </section>
    <section id="audience" class="value-summary">
      <div class="container">
        <div class="section-header section-header--center">
          <p class="eyebrow">Qué puede hacer VivaSpeak</p>
          <h2>
            Especialmente útil para negocios que reciben más consultas de las que pueden atender
          </h2>
          <p>
            Si una llamada o WhatsApp perdido significa una cita menos o un cliente que llama a la
            competencia, VivaSpeak está pensado para tu negocio.
          </p>
        </div>
        <div class="value-grid audience-grid">
          <article class="value-card">
            <h3>Respuestas a preguntas</h3>
            <p>
              Responde instantáneamente a cualquier pregunta que le hagan sobre tu negocio para que
              no tengas que repetir continuamente la misma información.
            </p>
          </article>
          <article class="value-card">
            <h3>Agendamiento de citas</h3>
            <p>
              Agenda visitas automáticamente. Refresca tu base de datos para ver qué contacto tiene
              potencial.
            </p>
          </article>
          <article class="value-card">
            <h3>Filtrado de leads</h3>
            <p>
              Cualifica al lead y no pierdas tiempo con interacciones que no llevan a ningún lado.
            </p>
          </article>
          <article class="value-card">
            <h3>Captación de leads</h3>
            <p>
              Contacta leads al instante por teléfono antes de que se enfríen para ver si realmente
              pueden traer algún valor.
            </p>
          </article>
          <article class="value-card">
            <h3>Envío de recordatorios</h3>
            <p>
              Envía mensajes antes de la cita para que tus clientes no se olviden y puedan
              confirmar.
            </p>
          </article>
          <article class="value-card">
            <h3>Envío de petición de reseñas</h3>
            <p>
              Pide a tus clientes que escriban unas palabras en Google sobre la experiencia con tu
              servicio.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section id="price" class="pricing-anchor">
      <div class="container">
        <div class="section-header section-header--center">
          <p class="eyebrow">Automatiza tu negocio desde el primer mes</p>
          <h2>Precio según volumen de llamadas e integraciones.</h2>
          <p>La mayoría de clientes empiezan entre 150 € y 400 € al mes.</p>
          <div class="cta-buttons">
            <a
              href="#contact"
              class="btn-primary"
              data-ga-event="pricing_try_agent_click"
              data-ga-location="pricing"
            >
              Pedir presupuesto
            </a>
          </div>
        </div>
      </div>
    </section>
    <section id="video-demo">
      <div class="container">
        <div class="section-header">
          <img src="/assets/video.png" alt="Icono de video" class="section-icon" />
          <p class="eyebrow">Demo interactiva</p>
          <h2>Mira cómo funciona en 90 segundos</h2>
          <p>
            En el siguiente vídeo puedes ver una integración con un software médico donde
            automatizamos reservas. Al paciente le resolvemos preguntas complejas y notificamos al
            equipo en cuestión de segundos.
          </p>
        </div>
        <div class="demo-grid">
          <div class="demo-video-card">
            <iframe
              width="315"
              height="560"
              src="https://www.youtube.com/embed/_MwMo-mlBGQ"
              title="Demo Clara VivaSpeak - Agente de voz IA para clínicas"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen></iframe>
          </div>
          <div class="demo-details">
            <ul class="checklist">
              <li>Reserva citas con confirmación en tiempo real.</li>
              <li>Tu equipo recibe un resumen automático por email.</li>
              <li>Puede transferir la llamada a una persona cuando la conversación lo exige.</li>
            </ul>

            <div class="cta-buttons">
              <a href="#contact" class="btn-primary">Haznos una pregunta</a>
              <a href="#schedule" class="btn-secondary">Reserva una reunión</a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <!-- Sección de Testimonios y Estudios de Caso -->
    <section id="testimonials">
      <div class="container">
        <div class="section-header section-header--center">
          <p class="eyebrow">Resultados reales</p>
          <h2>Testimonios y casos de éxito</h2>
          <p>
            Empresas de sectores muy distintos ya operan con agentes de VivaSpeak. Esto es lo que
            dicen después de implementar la plataforma.
          </p>
        </div>

        <div class="testimonials-grid">
          <!-- Testimonio 1: Daniel Insa (card compacta con vídeo) -->
          <div class="testimonial-item testimonial-item--video">
            <div class="testimonial-content">
              <div class="testimonial-author">
                <h3>Daniel Insa</h3>
                <p class="author-role">Agente inmobiliario</p>
                <p class="author-details">+15 años de experiencia en el sector</p>
              </div>

              <div class="testimonial-media">
                <iframe
                  width="315"
                  height="560"
                  src="https://www.youtube.com/embed/vmtha03C92E"
                  title="Testimonio de Daniel Insa - Agente inmobiliario"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen></iframe>
              </div>
            </div>
          </div>

          <!-- Testimonio 2: Reinaldo Rodríguez -->
          <div class="testimonial-item no-video">
            <div class="testimonial-content">
              <div class="testimonial-author">
                <h3>Reinaldo Rodríguez</h3>
                <p class="author-role">Director de AllGrass</p>
                <p class="author-details">Césped artificial y jardinería · Madrid</p>
              </div>

              <div class="testimonial-media">
                <img
                  src="/assets/allgrass-logo.webp"
                  alt="Logo AllGrass"
                  class="testimonial-placeholder"
                />
              </div>

              <blockquote class="testimonial-quote">
                "Gracias a VivaSpeak optimizamos la gestión de llamadas para prestar un mejor
                servicio. <strong>Rebeca</strong> atiende en
                <strong>4 idiomas</strong> y nos envía un email tras cada conversación. Ha sido una inversión
                que se ha pagado sola."
              </blockquote>

              <div class="testimonial-tags">
                <span class="tag">🌍 4 idiomas</span>
                <span class="tag">⚡ Respuesta instantánea</span>
                <span class="tag">🌱 Jardinería</span>
                <span class="tag">📊 Panel online</span>
              </div>
            </div>
          </div>

          <!-- Testimonio 3: Juan Taborda -->
          <div class="testimonial-item no-video">
            <div class="testimonial-content">
              <div class="testimonial-author">
                <h3>Juan Taborda</h3>
                <p class="author-role">Villas y Fincas Mallorca</p>
                <p class="author-details">20 años en el sector · Alquiler en Baleares</p>
              </div>

              <blockquote class="testimonial-quote">
                "El principal problema que teníamos era gestionar el alto volumen de llamadas,
                especialmente en alquiler —en Baleares puede haber 200+ solicitudes por una sola
                vivienda. Queríamos una atención más personalizada que un simple contestador. <strong
                  >Ahora atendemos 24h los 7 días, no perdemos contactos y precualificamos en una
                  fracción del tiempo</strong
                >, incluso en picos de demanda. Funciona muy bien, está muy pulido."
              </blockquote>

              <div class="testimonial-tags">
                <span class="tag">🏠 Alquiler Baleares</span>
                <span class="tag">⚡ Soporta picos</span>
                <span class="tag">📞 200+ solicitudes/vivienda</span>
                <span class="tag">✅ Filtro real</span>
              </div>
            </div>
          </div>

          <!-- Testimonio 4: Arturo Chavarría (mismo nivel que Juan, sin ilustración) -->
          <div class="testimonial-item no-video">
            <div class="testimonial-content">
              <div class="testimonial-author">
                <h3>Arturo Chavarría</h3>
                <p class="author-role">MyCantabria Inmobiliaria</p>
                <p class="author-details">Inmobiliaria · Cantabria</p>
              </div>

              <blockquote class="testimonial-quote">
                "La verdad es que la prueba ha sido perfecta y me ha gustado muchísimo. Considero
                que el servicio es muy funcional y suficiente para una inmobiliaria pequeña o
                mediana, especialmente para gestionar los contactos que no puedes atender cuando
                estás realizando otras funciones. <strong
                  >Sin lugar a dudas, volvería a contratar con VivaSpeak en el futuro.</strong
                >"
              </blockquote>

              <div class="testimonial-tags">
                <span class="tag">🏠 Inmobiliaria Cantabria</span>
                <span class="tag">📞 Gestión de contactos</span>
                <span class="tag">⚡ Atender cuando no puedes</span>
                <span class="tag">✅ Sin duda volvería</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="container">
        <img src="/assets/faq-icon.png" alt="Icono de preguntas frecuentes" class="image" />
        <h2>Preguntas Frecuentes (FAQ)</h2>
        <div class="faq-container">
          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Qué es exactamente VivaSpeak?
            </summary>
            <div class="faq-content">
              Un sistema de automatización de negocios, que se especializa en la comunicación por
              voz y WhatsApp. Para responder dudas usamos la información del negocio que es editable
              desde nuestro panel. Nuestros agentes se especializan en cualificar leads.
            </div>
          </details>

          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Cómo se estructura el precio?
            </summary>
            <div class="faq-content">
              El precio se define por agente según volumen, sector e integraciones. Te damos un
              único plan operativo sin desglose técnico.
            </div>
          </details>

          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Se integra con mis herramientas?
            </summary>
            <div class="faq-content">
              Sí. Conectamos Google Calendar, HubSpot, CRMs propios y agendas con API, además de la
              API oficial de WhatsApp. Incluimos guías de desvío y de compartición de calendario.
            </div>
          </details>

          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Puedo probarlo antes de contratarlo?
            </summary>
            <div class="faq-content">
              Cada agente incluye un piloto de una semana con tus flujos reales y KPIs compartidos
              en el panel.
            </div>
          </details>

          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Qué idiomas cubre?
            </summary>
            <div class="faq-content">
              Los agentes suelen usar un idioma principal y le podemos añadir hasta 3 adicionales,
              entre ellos se encuentran español, inglés, portugués, francés, italiano y alemán.
              Pregunta por otros idiomas o acentos antes del lanzamiento.
            </div>
          </details>

          <details class="faq">
            <summary>
              <span class="faq-arrow">▶</span>
              ¿Puede el agente de voz IA transferir la llamada a una persona?
            </summary>
            <div class="faq-content">
              Sí, se puede programar que por ejemplo en caso de urgencia o filtrado positivo se
              transfiera la llamada a la persona adecuada.
            </div>
          </details>
        </div>
      </div>
