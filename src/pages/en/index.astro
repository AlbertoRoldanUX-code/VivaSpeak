---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Icon from '../../components/Icon.astro';
const schemaFaq = [
  {
    question: 'What exactly is VivaSpeak?',
    answer:
      'A business automation system specialised in voice and WhatsApp communication. To answer questions, we use business information that is editable from our panel. Our agents are specialised in qualifying leads.',
  },
  {
    question: 'How is the pricing structured?',
    answer:
      'Pricing is defined per agent based on volume, sector, and integrations. You get a single operating plan with no technical breakdown.',
  },
  {
    question: 'Does it integrate with my tools?',
    answer:
      'Yes. We connect Google Calendar, HubSpot, proprietary CRMs, scheduling systems with API access, and the official WhatsApp API. We include guides for call forwarding and calendar sharing.',
  },
  {
    question: 'Can I try it before hiring?',
    answer:
      'Each agent includes a one-week pilot with your real workflows and shared KPIs on the dashboard.',
  },
  {
    question: 'What languages does it support?',
    answer:
      'Agents usually work with one main language and we can add up to three more, including Spanish, English, Portuguese, French, Italian, and German. Ask about other languages or accents before launch.',
  },
  {
    question: 'Can the AI voice agent transfer the call to a person?',
    answer:
      'Yes. It can be configured so that, for example, in urgent cases or after a positive filter, the call is transferred to the right person.',
  },
];

const schemaHowTo = {
  name: 'How VivaSpeak works',
  description: 'Your AI agent answers, qualifies, and books without friction in 6 steps.',
  step: [
    {
      name: 'A customer calls or writes on WhatsApp',
      text: 'The AI answers instantly with a natural voice.',
    },
    {
      name: 'The AI qualifies and answers questions',
      text: 'It uses your knowledge base to resolve real questions.',
    },
    {
      name: 'It books an appointment in your real calendar',
      text: 'Connect Google Calendar, CRM, or your internal schedule.',
    },
    {
      name: 'Your team receives an automatic summary',
      text: 'Email or WhatsApp with the conversation and the next action.',
    },
    {
      name: 'See every lead in a panel that is always available',
      text: 'A visual CRM where you can view, filter, and manage every contact at a glance.',
    },
    {
      name: 'Call or send messages from the panel without leaving the system',
      text: 'Trigger follow-ups, respond to contacts, and launch calls or messages from one place.',
    },
  ],
};

const schemaVideos = [
  {
    name: 'Clara VivaSpeak Demo - AI Voice Agent for clinics',
    description:
      'Real example where Clara answers a call, resolves questions about treatments and books an appointment automatically.',
    thumbnailUrl: 'https://img.youtube.com/vi/_MwMo-mlBGQ/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=_MwMo-mlBGQ',
    embedUrl: 'https://www.youtube.com/embed/_MwMo-mlBGQ',
  },
  {
    name: 'Testimonial by Daniel Insa - Real Estate Agent',
    description:
      'Daniel Insa, RE/MAX real estate agent in Malaga, explains how VivaSpeak helps him serve more clients without interrupting his work.',
    thumbnailUrl: 'https://img.youtube.com/vi/vmtha03C92E/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=vmtha03C92E',
    embedUrl: 'https://www.youtube.com/embed/vmtha03C92E',
  },
];

const schemaReviews = [
  {
    author: 'Daniel Insa',
    role: 'Real Estate Agent, RE/MAX · Malaga',
    body: 'Thanks to Laura, I can serve more clients without interrupting my work. She answers calls, filters enquiries and schedules viewings in my calendar.',
    rating: 5,
  },
  {
    author: 'Reinaldo Rodríguez',
    role: 'Director of AllGrass · Madrid',
    body: 'Thanks to VivaSpeak we optimised call management to deliver a better service. Rebeca handles 4 languages and sends us an email after every conversation. It has been an investment that paid for itself.',
    rating: 5,
  },
  {
    author: 'Juan Taborda',
    role: 'Villas y Fincas Mallorca · 20 years in the sector',
    body: "Now we answer 24/7, we don't lose contacts and we pre-qualify in a fraction of the time, even during demand peaks. It works really well, very polished.",
    rating: 5,
  },
  {
    author: 'Arturo Chavarría',
    role: 'MyCantabria Real Estate · Cantabria',
    body: "The service is very functional and sufficient for a small or medium real estate agency, especially for managing contacts you can't attend while doing other tasks. Without a doubt, I would hire VivaSpeak again in the future.",
    rating: 5,
  },
];
---

<Layout
  title="AI Agents for Calls and WhatsApp 24/7 | VivaSpeak"
  description="Handle calls, WhatsApp, and filter leads automatically 24/7. Book appointments, qualify contacts, and manage everything from one panel."
  canonical="https://vivaspeak.com/en/"
  alternateEs="https://vivaspeak.com/"
  alternateEn="https://vivaspeak.com/en/"
  ogImage="https://vivaspeak.com/assets/og-image.png"
  ogType="website"
  lang="en"
  keywords="voice assistant, virtual assistant, call automation, WhatsApp Business API, AI chatbot, clinic management, real estate, automated bookings, 24/7 customer service, scheduling integration"
  schemaFaq={schemaFaq}
  schemaHowTo={schemaHowTo}
  schemaVideos={schemaVideos}
  schemaReviews={schemaReviews}
  speakable={['.home-title', '.home-description', '.faq-content', '.card p']}
>
  <Header lang="en" />
  <main id="main-content">
    <section id="home" class="hero">
      <div class="container">
        <div class="hero-content">
          <p class="eyebrow">AI Agents for Business</p>
          <h1 class="home-title">Handle calls, WhatsApp, and filter leads automatically 24/7</h1>
          <p class="hero-subtitle home-description">
            Book appointments, qualify contacts, and use our CRM or update yours without
            interrupting your work
          </p>
          <div class="hero-actions">
            <a
              href="#schedule"
              class="btn btn-primary"
              data-ga-event="hero_try_agent_click"
              data-ga-location="hero"
            >
              Book meeting
            </a>
            <a
              href="#video-demo"
              class="btn btn-secondary"
              data-ga-event="hero_demo_click"
              data-ga-location="hero"
            >
              <Icon name="play" size={14} /> See how it works
            </a>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <strong>&lt; 2 s</strong>
              <span>average response time</span>
            </div>
            <div class="hero-stat">
              <strong>24/7</strong>
              <span>automated coverage</span>
            </div>
            <div class="hero-stat">
              <strong>0</strong>
              <span>missed calls</span>
            </div>
          </div>
        </div>
        <div class="hero-visual">
          <picture>
            <source srcset="/assets/whatsapp-mockup.webp" type="image/webp" />
            <img
              src="/assets/whatsapp-mockup.webp"
              alt="A VivaSpeak agent conversation on WhatsApp"
              fetchpriority="high"
              loading="eager"
            />
          </picture>
        </div>
      </div>
    </section>
    <section id="value-prop" class="section">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">How VivaSpeak works</p>
          <h2>Your AI agent answers, qualifies, and books without friction</h2>
        </div>
        <div class="grid grid-3">
          <article class="card">
            <div class="card-icon">1</div>
            <h3>A customer calls or writes on WhatsApp</h3>
            <p>The AI answers instantly with a natural voice.</p>
          </article>
          <article class="card">
            <div class="card-icon">2</div>
            <h3>The AI qualifies and answers questions</h3>
            <p>It uses your knowledge base to resolve real questions.</p>
          </article>
          <article class="card">
            <div class="card-icon">3</div>
            <h3>It books an appointment in your real calendar</h3>
            <p>Connect Google Calendar, CRM, or your internal schedule.</p>
          </article>
          <article class="card">
            <div class="card-icon">4</div>
            <h3>Your team receives an automatic summary</h3>
            <p>Email or WhatsApp with the conversation and the next action.</p>
          </article>
          <article class="card">
            <div class="card-icon">5</div>
            <h3>See every lead in a panel that is always available</h3>
            <p>A visual CRM where you can view, filter, and manage every contact at a glance.</p>
          </article>
          <article class="card">
            <div class="card-icon">6</div>
            <h3>Call or send messages from the panel without leaving the system</h3>
            <p>
              Trigger follow-ups, respond to contacts, and launch calls or messages from one place.
            </p>
          </article>
        </div>
      </div>
    </section>
    <section id="use-cases" class="section" style="background: var(--color-bg-subtle);">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">What problems VivaSpeak solves</p>
          <h2>Where calls, appointments, and leads usually slip through</h2>
        </div>
        <div class="grid grid-2">
          <article class="card">
            <h3>You cannot answer calls while you work</h3>
            <p>The agent answers, filters, and books for you without interrupting operations.</p>
          </article>
          <article class="card">
            <h3>People write outside business hours</h3>
            <p>WhatsApp answers automatically and keeps the conversation moving.</p>
          </article>
          <article class="card">
            <h3>You lose form leads</h3>
            <p>The AI calls or replies instantly before the lead goes cold.</p>
          </article>
          <article class="card">
            <h3>You get too many repetitive questions</h3>
            <p>The AI handles common questions and escalates only what matters.</p>
          </article>
        </div>
      </div>
    </section>
    <section id="audience" class="section">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">What VivaSpeak can do</p>
          <h2>For businesses that receive more enquiries than they can handle</h2>
          <p>
            If a missed call or WhatsApp means one less appointment or a customer calling a
            competitor, VivaSpeak is built for your business.
          </p>
        </div>
        <div class="grid grid-3">
          <article class="card">
            <h3>Answer questions</h3>
            <p>
              Answer questions about your business instantly so your team does not have to repeat
              the same information all day.
            </p>
          </article>
          <article class="card">
            <h3>Book appointments</h3>
            <p>
              Book visits automatically and refresh your database so you can see which contact has
              real potential.
            </p>
          </article>
          <article class="card">
            <h3>Filter leads</h3>
            <p>
              Qualify each lead and stop wasting time on interactions that are not going anywhere.
            </p>
          </article>
          <article class="card">
            <h3>Capture leads</h3>
            <p>
              Contact leads instantly by phone before they go cold and find out whether they can
              bring real value.
            </p>
          </article>
          <article class="card">
            <h3>Send reminders</h3>
            <p>Send messages before the appointment so customers remember and can confirm.</p>
          </article>
          <article class="card">
            <h3>Ask for reviews</h3>
            <p>
              Request a Google review after the interaction so happy customers help you grow trust.
            </p>
          </article>
        </div>
      </div>
    </section>
    <section id="price" class="section">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">Automate your business from the first month</p>
          <h2>Pricing depends on call volume and integrations.</h2>
          <p>Most customers start between €150 and €400 per month.</p>
          <div class="hero-actions" style="justify-content: center; margin-top: var(--space-6);">
            <a
              href="#contact"
              class="btn btn-primary"
              data-ga-event="pricing_try_agent_click"
              data-ga-location="pricing"
            >
              Request a quote
            </a>
          </div>
        </div>
      </div>
    </section>
    <section id="video-demo" class="section" style="background: var(--color-bg-subtle);">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">Interactive Demo</p>
          <h2>See how it works in 90 seconds</h2>
          <p>
            In the following video you can see an integration with medical software where we
            automate bookings. The patient gets complex questions answered and the team is notified
            in seconds.
          </p>
        </div>
        <div class="grid grid-2" style="align-items: center;">
          <div
            class="card"
            style="padding: 0; overflow: hidden; display: flex; justify-content: center;"
          >
            <iframe
              width="315"
              height="560"
              src="https://www.youtube.com/embed/_MwMo-mlBGQ"
              title="Clara VivaSpeak Demo - AI Voice Agent for clinics"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              style="border-radius: var(--radius-lg);"></iframe>
          </div>
          <div>
            <ul
              style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-4);"
            >
              <li style="display: flex; align-items: flex-start; gap: var(--space-3);">
                <span style="color: var(--primary); font-size: var(--text-xl);">✓</span>
                <span>Book appointments with real-time confirmation.</span>
              </li>
              <li style="display: flex; align-items: flex-start; gap: var(--space-3);">
                <span style="color: var(--primary); font-size: var(--text-xl);">✓</span>
                <span>Your team receives an automatic summary by email.</span>
              </li>
              <li style="display: flex; align-items: flex-start; gap: var(--space-3);">
                <span style="color: var(--primary); font-size: var(--text-xl);">✓</span>
                <span>It can transfer the call to a person when the conversation requires it.</span>
              </li>
            </ul>
            <div class="hero-actions" style="margin-top: var(--space-6);">
              <a href="#contact" class="btn btn-primary">Ask us a question</a>
              <a href="#schedule" class="btn btn-secondary">Book a meeting</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="testimonials" class="section" style="background: var(--color-bg-subtle);">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">Real Results</p>
          <h2>Testimonials and Success Stories</h2>
          <p>
            Companies from very different sectors already operate with VivaSpeak agents. This is
            what they say after implementing the platform.
          </p>
        </div>

        <div class="grid grid-2">
          <div class="card">
            <div style="margin-bottom: var(--space-4);">
              <h3>Daniel Insa</h3>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                Real Estate Agent
              </p>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                +15 years of experience in the sector
              </p>
            </div>
            <div style="border-radius: var(--radius-md); overflow: hidden;">
              <iframe
                width="315"
                height="560"
                src="https://www.youtube.com/embed/vmtha03C92E"
                title="Testimonial by Daniel Insa - Real Estate Agent"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                style="display: block; max-width: 100%;"></iframe>
            </div>
          </div>

          <div class="card">
            <div style="margin-bottom: var(--space-4);">
              <h3>Reinaldo Rodríguez</h3>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                Director of AllGrass
              </p>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                Artificial turf and gardening · Madrid
              </p>
            </div>
            <div style="margin-bottom: var(--space-4);">
              <img
                src="/assets/allgrass-logo.webp"
                alt="AllGrass Logo"
                style="max-height: 48px; width: auto;"
                loading="lazy"
              />
            </div>
            <blockquote
              style="font-style: italic; margin: 0 0 var(--space-4); line-height: var(--leading-relaxed); color: var(--color-text);"
            >
              "Thanks to VivaSpeak, we optimized call management to provide better service. <strong
                >Rebeca</strong
              > handles calls in
              <strong>4 languages</strong> and sends us an email after each conversation. It has been
              an investment that has paid for itself."
            </blockquote>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
              <span class="badge">🌍 4 languages</span>
              <span class="badge">⚡ Instant response</span>
              <span class="badge">🌱 Gardening</span>
              <span class="badge">📊 Online panel</span>
            </div>
          </div>

          <div class="card">
            <div style="margin-bottom: var(--space-4);">
              <h3>Juan Taborda</h3>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                Villas y Fincas Mallorca
              </p>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                20 years in the sector · Rental in the Balearic Islands
              </p>
            </div>
            <blockquote
              style="font-style: italic; margin: 0 0 var(--space-4); line-height: var(--leading-relaxed); color: var(--color-text);"
            >
              "The main problem we had was managing the high volume of calls, especially for rentals
              —in the Balearics there can be 200+ applications for a single property. We wanted a
              more personal service than a simple answering machine. <strong
                >Now we cover 24h, 7 days a week, we don't lose contacts, and we pre-qualify in a
                fraction of the time</strong
              >, even during demand peaks. It works very well, it's very polished."
            </blockquote>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
              <span class="badge">🏠 Rental Balearics</span>
              <span class="badge">⚡ Handles peaks</span>
              <span class="badge">📞 200+ leads/property</span>
              <span class="badge">✅ Real filter</span>
            </div>
          </div>

          <div class="card">
            <div style="margin-bottom: var(--space-4);">
              <h3>Arturo Chavarría</h3>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                MyCantabria Inmobiliaria
              </p>
              <p style="font-size: var(--text-sm); color: var(--color-text-muted); margin: 0;">
                Real Estate Agency · Cantabria
              </p>
            </div>
            <blockquote
              style="font-style: italic; margin: 0 0 var(--space-4); line-height: var(--leading-relaxed); color: var(--color-text);"
            >
              "The truth is that the trial was perfect and I liked it very much. I consider the
              service to be very functional and sufficient for a small or medium-sized estate
              agency, especially for managing contacts you cannot attend to when you are doing other
              tasks. <strong>Without a doubt, I would hire VivaSpeak again in the future.</strong>"
            </blockquote>
            <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
              <span class="badge">🏠 Cantabria Real Estate</span>
              <span class="badge">📞 Contact management</span>
              <span class="badge">⚡ Answer when you can't</span>
              <span class="badge">✅ Would hire again</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="faq" class="section">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">FAQ</p>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width: 720px; margin: 0 auto;">
          <details class="accordion">
            <summary>What exactly is VivaSpeak?</summary>
            <div class="accordion-content faq-content">
              A business automation system specialised in voice and WhatsApp communication. To
              answer questions, we use business information that is editable from our panel. Our
              agents are specialised in qualifying leads.
            </div>
          </details>

          <details class="accordion">
            <summary>How is the pricing structured?</summary>
            <div class="accordion-content faq-content">
              Pricing is defined per agent based on volume, sector, and integrations. You get a
              single operating plan with no technical breakdown.
            </div>
          </details>

          <details class="accordion">
            <summary>Does it integrate with my tools?</summary>
            <div class="accordion-content faq-content">
              Yes. We connect Google Calendar, HubSpot, proprietary CRMs, scheduling systems with
              API access, and the official WhatsApp API. We include guides for call forwarding and
              calendar sharing.
            </div>
          </details>

          <details class="accordion">
            <summary>Can I try it before hiring?</summary>
            <div class="accordion-content faq-content">
              Each agent includes a one-week pilot with your real workflows and shared KPIs on the
              dashboard.
            </div>
          </details>

          <details class="accordion">
            <summary>What languages does it support?</summary>
            <div class="accordion-content faq-content">
              Agents usually work with one main language and we can add up to three more, including
              Spanish, English, Portuguese, French, Italian, and German. Ask about other languages
              or accents before launch.
            </div>
          </details>

          <details class="accordion">
            <summary>Can the AI voice agent transfer the call to a person?</summary>
            <div class="accordion-content faq-content">
              Yes. It can be configured so that, for example, in urgent cases or after a positive
              filter, the call is transferred to the right person.
            </div>
          </details>
        </div>
      </div>
    </section>
    <section id="contact" class="section">
      <div class="container">
        <div
          class="card"
          style="text-align: center; padding: var(--space-6); margin-bottom: var(--space-10); background: var(--color-bg-subtle);"
        >
          <p style="font-weight: var(--font-semibold); margin: 0 0 var(--space-2);">
            📞 Prefer to talk?
          </p>
          <p style="margin: 0; color: var(--color-text-muted);">
            Call
            <strong
              ><a href="tel:+34951798932" style="color: var(--primary-dark); text-decoration: none;"
                >+34 951 798 932</a
              ></strong
            >
            and our AI agent will give you the basics while connecting you with a specialist.
          </p>
        </div>
        <div class="section-header text-center">
          <p class="eyebrow">Contact</p>
          <h2>Tell us what you need to automate</h2>
          <p>We respond the same day.</p>
        </div>
        <div class="grid grid-2" style="align-items: start;">
          <div class="card">
            <h3>What will you receive?</h3>
            <ul
              style="list-style: none; padding: 0; margin: var(--space-4) 0; display: flex; flex-direction: column; gap: var(--space-3);"
            >
              <li>✅ Agent and required channels recommendation.</li>
              <li>🛠️ Integration checklist (calendars, CRM, scheduling).</li>
              <li>💰 Clear costs for setup and support.</li>
            </ul>
            <div
              style="padding: var(--space-4); background: var(--color-bg-subtle); border-radius: var(--radius-md);"
            >
              <p style="margin: 0 0 var(--space-2); font-weight: var(--font-medium);">
                Support: Mon-Fri 9:00-19:00 CET
              </p>
              <a
                href="tel:+34951798932"
                style="color: var(--primary-dark); text-decoration: none; font-weight: var(--font-semibold);"
                >+34 951 798 932</a
              >
            </div>
          </div>
          <div>
            <form
              action="/en/success"
              name="contact"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              data-ga-submit="form_submit"
              data-ga-location="contact_form"
              style="display: flex; flex-direction: column; gap: var(--space-4);"
            >
              <input type="hidden" name="form-name" value="contact" />
              <div>
                <label for="name">Name</label>
                <input type="text" name="name" id="name" required />
              </div>
              <div>
                <label for="email">Email</label>
                <input type="email" name="email" id="email" required />
              </div>
              <div>
                <label for="solution-type">What do you need to automate?</label>
                <div
                  style="display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-2);"
                >
                  <label
                    style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); color: var(--color-text);"
                  >
                    <input type="radio" name="solution-type" value="leads-sales" required />
                    Lead capture / sales
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); color: var(--color-text);"
                  >
                    <input type="radio" name="solution-type" value="bookings" />
                    Bookings and scheduling
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); color: var(--color-text);"
                  >
                    <input type="radio" name="solution-type" value="support" />
                    Support / customer service
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); color: var(--color-text);"
                  >
                    <input type="radio" name="solution-type" value="operations" />
                    Internal operations / HR
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-base); color: var(--color-text);"
                  >
                    <input type="radio" name="solution-type" value="not-sure" />
                    I'm not sure
                  </label>
                </div>
              </div>
              <div>
                <label for="message">Message</label>
                <textarea name="message" id="message" required></textarea>
              </div>
              <div style="display: flex; align-items: flex-start; gap: var(--space-2);">
                <input type="checkbox" id="privacy-consent" required />
                <label
                  for="privacy-consent"
                  style="font-size: var(--text-sm); color: var(--color-text);"
                >
                  I accept the
                  <a href="terms-and-conditions" target="_blank" style="color: var(--primary-dark);"
                    >Terms and Conditions</a
                  >
                  and the
                  <a href="privacy-policy" target="_blank" style="color: var(--primary-dark);"
                    >Privacy Policy</a
                  >.
                </label>
              </div>
              <div data-netlify-recaptcha="true"></div>
              <button type="submit" class="btn btn-primary" style="width: 100%;"> Send </button>
            </form>
          </div>
        </div>
        <div
          id="schedule"
          class="card"
          style="margin-top: var(--space-12); text-align: center;"
          aria-label="Schedule a meeting"
        >
          <h3>Prefer to choose a time?</h3>
          <p style="color: var(--color-text-muted);">Book a demo with screen sharing.</p>
          <div class="calendly-inline-widget" data-url="https://calendly.com/vivaspeak/30min"></div>
        </div>
      </div>
    </section>
    <section class="section" style="background: var(--color-bg-subtle);">
      <div
        class="container"
        style="display: flex; flex-direction: column; gap: var(--space-6); align-items: center; text-align: center;"
      >
        <div>
          <p class="eyebrow">Final push</p>
          <h3
            style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--gray-900); margin: var(--space-3) 0 0; line-height: var(--leading-tight);"
          >
            In 7 days you can have an AI agent handling calls and WhatsApp automatically.
          </h3>
          <p
            style="font-size: var(--text-lg); color: var(--color-text-muted); margin: var(--space-3) 0 0; line-height: var(--leading-relaxed);"
          >
            We configure the agent around your business so you stop losing opportunities because
            nobody replied in time.
          </p>
        </div>
        <div class="hero-actions" style="justify-content: center;">
          <a
            href="#contact"
            class="btn btn-primary"
            data-ga-event="footer_try_agent_click"
            data-ga-location="footer"
          >
            Send a question
          </a>
          <a href="#schedule" class="btn btn-secondary">Book a time to talk</a>
        </div>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</Layout>
