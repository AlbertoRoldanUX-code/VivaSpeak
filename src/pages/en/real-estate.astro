---
import Layout from '../../layouts/Layout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
import Footer from '../../components/Footer.astro';
import '../../../styles/landing.css';

const schemaFaq = [
  {
    question: 'What does Laura do?',
    answer:
      'Answers calls 24/7, qualifies (rental/sale, budget, profile), schedules visits, and sends you an email with transcript and summary after each call.',
  },
  {
    question: 'Does it work with my number?',
    answer: 'Yes. We redirect your number to the agent or assign you a new one. No carrier change.',
  },
  {
    question: 'Can I listen to recordings?',
    answer:
      'Yes. Every call is in your dashboard with recording, transcript, and summary. Filter by date and result.',
  },
  {
    question: 'Can I try it with no commitment?',
    answer: 'Yes. Book a demo, we show the dashboard and do a test call. No contract.',
  },
  {
    question: 'Do I need to install anything?',
    answer:
      'No. Everything in the cloud: dashboard access, you upload your catalog, and Laura uses your info.',
  },
  {
    question: 'Does it work for high-demand rental (200+ calls)?',
    answer:
      "Yes. That's exactly what it's for. It filters, records, and shows the owner why the property hasn't been let yet.",
  },
];

const breadcrumb = [
  { name: 'Home', url: 'https://vivaspeak.com/en/' },
  { name: 'Laura for Real Estate', url: 'https://vivaspeak.com/en/real-estate/' },
];

const schemaVideos = [
  {
    name: 'Testimonial by Daniel Insa - Real Estate Agent',
    description:
      'Daniel Insa, RE/MAX real estate agent in Malaga, explains how VivaSpeak helps him serve more clients without interrupting his work.',
    thumbnailUrl: 'https://img.youtube.com/vi/vmtha03C92E/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=vmtha03C92E',
    embedUrl: 'https://www.youtube.com/embed/vmtha03C92E',
  },
];

const schemaReviews = [
  {
    author: 'Daniel Insa',
    role: 'Real Estate Agent, RE/MAX · Malaga',
    body: 'Thanks to Laura, I can serve more clients without interrupting my work. She answers calls, filters enquiries and schedules viewings in my calendar.',
    rating: 5,
  },
  {
    author: 'Juan Taborda',
    role: 'Villas y Fincas Mallorca · 20 years in the sector',
    body: "Now we answer 24/7, we don't lose contacts and we pre-qualify in a fraction of the time, even during demand peaks. It works really well, very polished.",
    rating: 5,
  },
  {
    author: 'Arturo Chavarría',
    role: 'MyCantabria Real Estate · Cantabria',
    body: "The service is very functional and sufficient for a small or medium real estate agency, especially for managing contacts you can't attend while doing other tasks. Without a doubt, I would hire VivaSpeak again in the future.",
    rating: 5,
  },
];
---

<Layout
  title="AI Voice Agent for Real Estate | Laura 24/7 | VivaSpeak"
  description="Laura handles calls 24/7, pre-qualifies leads and schedules viewings. Works with Idealista. Never miss a lead. Free demo."
  canonical="https://vivaspeak.com/en/real-estate/"
  alternateEs="https://vivaspeak.com/inmobiliaria/"
  alternateEn="https://vivaspeak.com/en/real-estate/"
  ogImage="https://vivaspeak.com/assets/og-image-inmobiliaria.jpg"
  keywords="voice agent, real estate, artificial intelligence, real estate calls, visit scheduling, client service, call automation, virtual agent"
  lang="en"
  schemaFaq={schemaFaq}
  schemaVideos={schemaVideos}
  schemaReviews={schemaReviews}
  breadcrumb={breadcrumb}
  speakable={['.hero-subtitle', '.hero-proof', '.faq-content', '.use-case-features li']}
>
  <LandingHeader lang="en" ctaLabel="Activate Your Agent" ctaHref="#cta-final" />
  <main id="main-content" class="landing"></main></Layout
>
<section class="landing-hero landing-hero--centered">
  <div class="container hero-content">
    <h1 class="hero-title">Answer every call. Pre-qualify in seconds. Don't lose a lead.</h1>
    <p class="hero-subtitle" style="font-style: italic; font-size: var(--text-sm);">
      Real result: +12% scheduled visits in 30 days (agency in Malaga).
    </p>
    <p class="eyebrow">
      Real estate agencies in Spain (Balearics, Malaga…) · 24/7 · Works with Idealista & Fotocasa
    </p>
    <p class="hero-subtitle">
      Laura, your AI voice assistant: filters rental vs sale, collects data, and sends you only
      contacts worth calling back.
    </p>
    <p class="hero-subtitle">
      High volume without hours on the phone. Export and show owners the work you're doing.
    </p>
    <div class="hero-actions">
      <a href="#cta-final" class="btn btn-primary">See live demo</a>
    </div>
  </div>
</section>

<section class="section" style="background: var(--color-bg);">
  <div class="container">
    <div class="section-header text-center">
      <h2>The real problem for real estate agencies</h2>
    </div>
    <ul class="use-case-features">
      <li>You say "message only" and people call anyway — you can't keep up</li>
      <li>Hundreds of enquiries per rental and no time to filter</li>
      <li>Owners ask why it isn't let and you have no way to show the work you've done</li>
    </ul>
    <p style="margin-top: var(--space-4); color: var(--color-text-muted);">
      If this sounds familiar, this page is for you.
    </p>
  </div>
</section>

<section class="section">
  <div class="container" style="text-align: center;">
    <p
      style="max-width: 720px; margin: 0 auto; color: var(--color-text-muted); font-size: var(--text-lg);"
    >
      With <strong>Laura</strong>, your voice assistant, every call is answered, qualified
      (rental/sale, solvency, profile), and you only call back those who matter. Works with your
      number or with Idealista/Fotocasa.
    </p>
  </div>
  <img
    src="/assets/inmobiliaria.png"
    alt="Laura, voice assistant for real estate clients"
    style="display: block; margin: var(--space-8) auto; max-width: min(720px, 92vw); border-radius: var(--radius-lg); border: 1px solid var(--color-border); box-shadow: var(--shadow-lg);"
  />
  <div class="container">
    <div class="section-header text-center">
      <h2>In four points</h2>
    </div>
    <div class="grid grid-2">
      <div class="card">
        <h3>📞 Answer</h3>
        <p>Calls 24/7 — none are missed</p>
      </div>
      <div class="card">
        <h3>🔎 Filter</h3>
        <p>Rental and sale with your criteria (date, solvency, profile)</p>
      </div>
      <div class="card">
        <h3>📧 You get only the good ones</h3>
        <p>Email per call with transcript and data so you decide who to call</p>
      </div>
      <div class="card">
        <h3>📊 Prove it to the owner</h3>
        <p>Dashboard with history and export</p>
      </div>
    </div>
  </div>
</section>

<section class="section landing-video">
  <div class="container">
    <img src="/assets/video.png" alt="Video icon" class="image" />
    <h2>Who's already using it</h2>

    <div class="testimonial-block">
      <h3 class="testimonial-block__title">Video testimonial</h3>
      <p class="testimonial-block__author">
        <strong>Daniel Insa</strong> – RE/MAX agent · Malaga
      </p>
      <p class="testimonial-block__quote">
        <em
          >"Thanks to Laura, I can serve more clients without interrupting my work. She answers
          calls, filters inquiries, and schedules visits in my calendar."</em
        >
      </p>
      <iframe
        width="315"
        height="560"
        src="https://www.youtube.com/embed/vmtha03C92E"
        title="Testimonial from Daniel Insa - Real Estate Agent"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen></iframe>
    </div>

    <div
      class="testimonial-block"
      style="padding-top: var(--space-6); border-top: 1px solid var(--color-border);"
    >
      <h3 class="testimonial-block__title">Other agencies</h3>
      <div class="testimonial-quote-block">
        <p class="testimonial-quote-label">
          Juan Taborda – Villas y Fincas Mallorca · 20 years in the sector · Mallorca
        </p>
        <blockquote>
          "The main problem we had was managing the high volume of calls, especially for rentals —in
          the Balearics there can be 200+ applications for a single property. We wanted a more
          personal service than a simple answering machine. <strong
            >Now we cover 24h, 7 days a week, we don't lose contacts, and we pre-qualify in a
            fraction of the time</strong
          >, even during demand peaks. It works very well, it's very polished."
        </blockquote>
      </div>
      <div class="testimonial-quote-block">
        <p class="testimonial-quote-label">
          Arturo Chavarría – MyCantabria Inmobiliaria · Cantabria
        </p>
        <blockquote>
          "The truth is that the trial was perfect and I liked it very much. I consider the service
          to be very functional and sufficient for a small or medium-sized estate agency, especially
          for managing contacts you cannot attend to when you are doing other tasks. <strong
            >Without a doubt, I would hire VivaSpeak again in the future.</strong
          >"
        </blockquote>
      </div>
    </div>

    <p class="testimonial-cta">
      <a href="#cta-final" class="btn btn-primary">See live demo</a>
    </p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <h2>Frequently Asked Questions</h2>
    </div>
    <div style="max-width: 860px; margin: 0 auto;">
      <details class="accordion">
        <summary>What does Laura do?</summary>
        <div class="accordion-content">
          Answers calls 24/7, qualifies (rental/sale, budget, profile), schedules visits, and sends
          you an email with transcript and summary after each call.
        </div>
      </details>
      <details class="accordion">
        <summary>Does it work with my number?</summary>
        <div class="accordion-content">
          Yes. We redirect your number to the agent or assign you a new one. No carrier change.
        </div>
      </details>
      <details class="accordion">
        <summary>Can I listen to recordings?</summary>
        <div class="accordion-content">
          Yes. Every call is in your dashboard with recording, transcript, and summary. Filter by
          date and result.
        </div>
      </details>
      <details class="accordion">
        <summary>Can I try it with no commitment?</summary>
        <div class="accordion-content">
          Yes. Book a demo, we show the dashboard and do a test call. No contract.
        </div>
      </details>
      <details class="accordion">
        <summary>Do I need to install anything?</summary>
        <div class="accordion-content">
          No. Everything in the cloud: dashboard access, you upload your catalog, and Laura uses
          your info.
        </div>
      </details>
      <details class="accordion">
        <summary>Does it work for high-demand rental (200+ calls)?</summary>
        <div class="accordion-content">
          Yes. That's exactly what it's for. It filters, records, and shows the owner why the
          property hasn't been let yet.
        </div>
      </details>
    </div>
  </div>
</section>

<section id="cta-final" class="section" style="background: var(--color-bg-subtle);">
  <div class="container" style="text-align: center;">
    <div class="section-header text-center">
      <h2>How does it work?</h2>
    </div>
    <div class="workflow" style="max-width: 570px; margin: 0 auto;">
      <div class="workflow-step">
        <span>1</span>
        <div>
          <h4>Dashboard access</h4>
          <p>Upload your catalog (or send it to us).</p>
        </div>
      </div>
      <div class="workflow-step">
        <span>2</span>
        <div>
          <h4>Laura answers 24/7</h4>
          <p>With your filter criteria.</p>
        </div>
      </div>
      <div class="workflow-step">
        <span>3</span>
        <div>
          <h4>Email per call</h4>
          <p>See everything in the dashboard. You only call back who matters.</p>
        </div>
      </div>
    </div>
    <p
      style="margin-top: var(--space-6); font-weight: var(--font-semibold); color: var(--color-text-muted);"
    >
      Live in days. No installation.
    </p>
    <div style="margin-top: var(--space-4);">
      <a href="https://calendly.com/vivaspeak/30min" class="btn btn-secondary">See live demo</a>
    </div>
  </div>
</section>

<section class="section pricing-anchor">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Pricing</p>
      <h2>From €249/month. Final pricing defined in demo based on volume and integrations.</h2>
    </div>
  </div>
</section>

<Footer lang="en" langEnHref="/en/real-estate" langEsHref="/inmobiliaria" />
