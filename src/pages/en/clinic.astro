---
import Layout from '../../layouts/Layout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
import Footer from '../../components/Footer.astro';
import '../../../styles/landing.css';

const schemaFaq = [
  {
    question: 'Can Clara integrate with my calendar?',
    answer: 'Yes. We can connect her to Google Calendar to schedule appointments automatically.',
  },
  {
    question: 'Can she handle emergencies?',
    answer:
      'Clara does not replace medical staff, but she can detect urgent words and redirect accordingly.',
  },
  {
    question: 'Can I test her before paying?',
    answer: 'Yes, you can try her with real calls and cancel anytime.',
  },
  {
    question: 'How do I redirect my current number?',
    answer:
      'You can redirect your number to Clara using a simple code. Download the step-by-step guide (PDF) from our docs.',
  },
];

const breadcrumb = [
  { name: 'Home', url: 'https://vivaspeak.com/en/' },
  { name: 'Clara for Clinics', url: 'https://vivaspeak.com/en/clinic/' },
];

const schemaVideos = [
  {
    name: 'Clara VivaSpeak Demo - AI Voice Agent for clinics',
    description:
      'Real example where Clara answers a call, resolves questions about treatments and books an appointment automatically.',
    thumbnailUrl: 'https://img.youtube.com/vi/un1BHBVSBVg/maxresdefault.jpg',
    uploadDate: '2024-06-01T00:00:00+02:00',
    contentUrl: 'https://www.youtube.com/watch?v=un1BHBVSBVg',
    embedUrl: 'https://www.youtube.com/embed/un1BHBVSBVg',
  },
];
---

<Layout
  title="AI Voice Agent for Clinics | Clara 24/7 | VivaSpeak"
  description="Clara schedules appointments, answers WhatsApp and reduces missed calls. Your clinic available 24/7. Free demo."
  canonical="https://vivaspeak.com/en/clinic/"
  alternateEs="https://vivaspeak.com/clinica/"
  alternateEn="https://vivaspeak.com/en/clinic/"
  keywords="voice agent, medical clinic, artificial intelligence, appointment scheduling, call automation, patient care, virtual assistant"
  ogImage="/assets/og-image-clinica.png"
  lang="en"
  schemaFaq={schemaFaq}
  schemaVideos={schemaVideos}
  breadcrumb={breadcrumb}
  speakable={['.hero-subtitle', '.faq-content', '.solution-card p']}
>
  <LandingHeader
    lang="en"
    ctaLabel="Activate Clara"
    ctaHref="https://calendly.com/vivaspeak/30min"
  />

  <main id="main-content" class="landing">
    <section class="landing-hero landing-hero--centered">
      <div class="container hero-content">
        <h1 class="hero-title">Automate Your Clinic with Clara – 24/7 Voice Assistant</h1>
        <img
          src="/assets/clara-avatar.png"
          alt="Clara, voice assistant for clinics"
          class="avatar-agent"
          loading="lazy"
        />
        <p class="hero-subtitle">
          Clara answers phone calls, resolves medical FAQs and schedules appointments directly in
          your calendar.
        </p>
        <div class="hero-actions">
          <a href="https://calendly.com/vivaspeak/30min" class="btn btn-primary">
            Activate Clara for your clinic
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header text-center">
          <h2>What Clara Does for Your Clinic</h2>
        </div>
        <ul class="use-case-features">
          <li>
            📞 <strong>Answers calls 24/7</strong>: Clara responds with empathy anytime.
          </li>
          <li>
            📅 <strong>Schedules appointments automatically</strong>: Connected to your Google
            Calendar to avoid overlaps.
          </li>
          <li>
            💬 <strong>Handles frequent questions</strong>: Opening hours, pricing, specialties…
            without staff intervention.
          </li>
          <li>
            🧑‍⚕️ <strong>Basic triage</strong>: Classifies and redirects patients if needed.
          </li>
          <li>
            🎧 <strong>Recordings available</strong>: Review calls in your panel if desired.
          </li>
        </ul>
      </div>
    </section>

    <section class="section landing-video">
      <div class="container">
        <img src="/assets/video.png" alt="Video icon" class="image" loading="lazy" />
        <h2>Watch Clara in Action</h2>
        <p>
          See a real example where Clara answers a call, resolves questions and books a visit in
          Google Calendar.
        </p>
        <iframe
          width="315"
          height="560"
          src="https://www.youtube.com/embed/un1BHBVSBVg"
          title="Demo Clara VivaSpeak"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen></iframe>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2>Listen to Clara</h2>
        <audio controls style="width: 100%; max-width: 480px;">
          <source src="/assets/audio-clara-ingles.mp3" type="audio/mpeg" />
          Your browser does not support the audio element.
        </audio>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header text-center">
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width: 860px; margin: 0 auto;">
          <details class="accordion">
            <summary>Can Clara integrate with my calendar?</summary>
            <div class="accordion-content">
              Yes. We can connect her to Google Calendar to schedule appointments automatically.
            </div>
          </details>
          <details class="accordion">
            <summary>Can she handle emergencies?</summary>
            <div class="accordion-content">
              Clara does not replace medical staff, but she can detect urgent words and redirect
              accordingly.
            </div>
          </details>
          <details class="accordion">
            <summary>Can I test her before paying?</summary>
            <div class="accordion-content">
              Yes, you can try her with real calls and cancel anytime.
            </div>
          </details>
          <details class="accordion">
            <summary>How do I redirect my current number?</summary>
            <div class="accordion-content">
              You can redirect your number to Clara using a simple code.
              <br /><br />
              👉
              <a href="/docs/guide-redirection.pdf" target="_blank" class="link-style">
                Download the step-by-step guide (PDF)
              </a>
            </div>
          </details>
          <details class="accordion">
            <summary>How do I share my calendar with Clara?</summary>
            <div class="accordion-content">
              To let Clara schedule appointments, just share your Google Calendar with us.
              <br /><br />
              👉
              <a href="/docs/guide-share-calendar.pdf" target="_blank" class="link-style">
                Download the guide (PDF)
              </a>
            </div>
          </details>
        </div>
      </div>
    </section>

    <section class="section pricing-anchor">
      <div class="container">
        <div class="section-header text-center">
          <p class="eyebrow">Single Price Point</p>
          <h2>From €249/month. Final pricing defined in demo based on volume and integrations.</h2>
          <div class="cta-buttons">
            <a href="#cta" class="btn btn-primary">Request demo</a>
          </div>
        </div>
      </div>
    </section>

    <section id="cta" class="landing-hero landing-hero--centered">
      <div class="container hero-content">
        <h2 class="hero-title" style="font-size: var(--text-3xl);">
          Ready to save time and serve more patients?
        </h2>
        <img
          src="/assets/clara-avatar.png"
          alt="Clara, voice assistant"
          class="avatar-agent"
          loading="lazy"
        />
        <div class="hero-actions">
          <a href="https://calendly.com/vivaspeak/30min" class="btn btn-primary">
            💡 Activate Clara Now
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang="en" langEnHref="/en/clinic" langEsHref="/clinica" />
</Layout>
