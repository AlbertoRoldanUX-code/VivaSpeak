---
import Layout from '../../../layouts/Layout.astro';
import LandingHeader from '../../../components/LandingHeader.astro';
import Footer from '../../../components/Footer.astro';
import '../../../../styles/resources.css';
import { offices } from '../../../data/offices';

const grouped = offices.reduce<Record<string, typeof offices>>((acc, o) => {
  (acc[o.province] ??= []).push(o);
  return acc;
}, {});
const provinces = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'es'));

const breadcrumb = [
  { name: 'Home', url: 'https://vivaspeak.com/en/' },
  { name: 'Locations', url: 'https://vivaspeak.com/en/locations/' },
];
---

<Layout
  title="Locations | AI Voice Agent across Spain | VivaSpeak"
  description="Find your VivaSpeak office. AI voice agents and WhatsApp chatbots in over 50 cities across Spain."
  canonical="https://vivaspeak.com/en/locations/"
  alternateEs="https://vivaspeak.com/ubicaciones/"
  alternateEn="https://vivaspeak.com/en/locations/"
  lang="en"
  breadcrumb={breadcrumb}
>
  <LandingHeader lang="en" ctaLabel="Request a demo" ctaHref="/en/#schedule" secondaryHref="/en/" />

  <main id="main-content">
    <section class="resource-hero">
      <div class="container">
        <h1 class="resource-title">Our locations</h1>
        <p class="resource-subtitle">AI voice agents in over 50 cities across Spain.</p>
      </div>
    </section>

    <section class="resource-grid-section">
      <div class="container">
        {
          provinces.map((province) => (
            <div style="margin-bottom: 2rem;">
              <h2 style="font-size: 1.4rem; margin-bottom: 1rem; color: #0b3a2a;">{province}</h2>
              <div class="resource-grid">
                {grouped[province].map((office) => (
                  <article class="resource-card">
                    <h3>{office.city}</h3>
                    <p>{office.coworking}</p>
                    <a href={`/en/locations/${office.slug}/`} class="resource-link">
                      View office →
                    </a>
                  </article>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <Footer lang="en" langEnHref="/en/locations/" langEsHref="/ubicaciones/" />
</Layout>
