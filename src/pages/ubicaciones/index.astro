---
import Layout from '../../layouts/Layout.astro';
import LandingHeader from '../../components/LandingHeader.astro';
import Footer from '../../components/Footer.astro';
import '../../../styles/locations-index.css';
import { offices } from '../../data/offices';

const sorted = offices.slice().sort((a, b) => a.city.localeCompare(b.city, 'es'));

const breadcrumb = [
  { name: 'Inicio', url: 'https://vivaspeak.com/' },
  { name: 'Ubicaciones', url: 'https://vivaspeak.com/ubicaciones/' },
];
---

<Layout
  title="Ubicaciones | Agente de Voz IA en toda España | VivaSpeak"
  description="Encuentra tu oficina VivaSpeak. Agentes de voz IA y chatbots de WhatsApp en más de 50 ciudades de España."
  canonical="https://vivaspeak.com/ubicaciones/"
  alternateEs="https://vivaspeak.com/ubicaciones/"
  alternateEn="https://vivaspeak.com/en/locations/"
  lang="es"
  breadcrumb={breadcrumb}
>
  <LandingHeader ctaLabel="Solicitar demo" ctaHref="/#schedule" secondaryHref="/" />

  <main id="main-content">
    <section class="locations-hero">
      <div class="container">
        <p class="eyebrow">
          <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Ubicaciones
        </p>
        <h1>Agente de Voz IA en toda España</h1>
        <p class="locations-hero__sub">
          Automatiza llamadas, WhatsApp y atención al cliente con IA desde cualquier ciudad.
        </p>
        <div class="locations-hero__stats">
          <div class="locations-hero__stat">
            <strong>{sorted.length}+</strong>
            <span>ciudades</span>
          </div>
          <div class="locations-hero__stat">
            <strong>24/7</strong>
            <span>atención automática</span>
          </div>
          <div class="locations-hero__stat">
            <strong>&lt; 2s</strong>
            <span>tiempo de respuesta</span>
          </div>
        </div>
      </div>
    </section>

    <div class="locations-filter">
      <div class="container">
        <input
          type="text"
          class="locations-filter__input"
          id="locationSearch"
          placeholder="Buscar ciudad o provincia…"
          aria-label="Buscar ciudad o provincia"
        />
      </div>
    </div>

    <section class="locations-grid-section">
      <div class="container">
        <div class="locations-grid" id="locationsGrid">
          {
            sorted.map((office) => (
              <a
                href={`/ubicaciones/${office.slug}/`}
                class="location-card"
                data-city={office.city.toLowerCase()}
                data-province={office.province.toLowerCase()}
              >
                <div class="location-card__icon">
                  <i class="fa-solid fa-building" aria-hidden="true" />
                </div>
                <p class="location-card__province">{office.province}</p>
                <h3>{office.city}</h3>
                <p class="location-card__coworking">{office.coworking}</p>
                <span class="location-card__link">
                  Ver oficina <i class="fa-solid fa-arrow-right" aria-hidden="true" />
                </span>
              </a>
            ))
          }
        </div>
        <p class="locations-empty" id="locationsEmpty">No se encontraron resultados.</p>
      </div>
    </section>

    <section class="locations-cta">
      <div class="container">
        <p class="eyebrow">¿Listo para empezar?</p>
        <h2>Automatiza tu negocio hoy</h2>
        <p>Solicita una demo personalizada y descubre cómo VivaSpeak puede ayudarte.</p>
        <div class="cta-buttons">
          <a href="/#schedule" class="btn-primary">Solicitar demo</a>
          <a
            href="https://wa.me/34951795151"
            class="btn-secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <i class="fa-brands fa-whatsapp" aria-hidden="true"></i> WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer langEnHref="/en/locations/" langEsHref="/ubicaciones/" />
</Layout>

<script is:inline>
  const input = document.getElementById('locationSearch');
  const grid = document.getElementById('locationsGrid');
  const empty = document.getElementById('locationsEmpty');
  if (input && grid) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let visible = 0;
      grid.querySelectorAll('.location-card').forEach((card) => {
        const match = card.dataset.city.includes(q) || card.dataset.province.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    });
  }
</script>
