---
import Layout from '../layouts/Layout.astro';
import LandingHeader from '../components/LandingHeader.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import '../../styles/landing.css';

const schemaFaq = [
  {
    question: '¿Se puede personalizar por especialidad?',
    answer:
      'Sí, 100%. Definimos preguntas, criterios de descarte y orden del flujo según tu especialidad.',
  },
  {
    question: '¿Graba llamadas?',
    answer: 'Sí, con aviso legal automático desde el primer segundo.',
  },
  {
    question: '¿En cuánto tiempo está listo?',
    answer: '24 horas desde que recibimos tu contexto.',
  },
  {
    question: '¿Cumple RGPD y normativa de grabación en España?',
    answer:
      'Sí. Incluye aviso legal automático al inicio de la llamada y se adapta a la normativa de grabación en España.',
  },
];

const mainEntityService = {
  name: 'Agente de voz IA para abogados',
  description:
    'Agente de voz IA que filtra llamadas legales, recoge datos clave y envía resúmenes estructurados a despachos de abogados.',
  areaServed: 'ES',
  availableLanguage: ['es', 'en', 'de'],
};
---

<Layout
  title="Agente de voz IA para abogados | VivaSpeak"
  description="VivaSpeak atiende y filtra llamadas legales, recoge datos clave y envía resúmenes listos para decidir. Atención 24/7, multidioma y con aviso de grabación."
  canonical="https://vivaspeak.com/abogados"
  alternateEs="https://vivaspeak.com/abogados"
  ogImage="/assets/og-image.png"
  lang="es"
  keywords="agente de voz IA, abogados, despacho legal, recepción telefónica legal, atención telefónica abogados, cualificación de casos legales"
  schemaFaq={schemaFaq}
  speakable={['.hero-title', '.hero-subtitle', '.faq-card p']}
  schemaMainEntityService={mainEntityService}
>
  <LandingHeader ctaLabel="Agendar demo" ctaHref="#cta-final" />
  <main id="main-content" class="landing law-landing"></main></Layout
>
<!-- HERO -->
<section class="landing-hero law-hero">
  <div class="container hero-grid">
    <div>
      <p class="eyebrow law-eyebrow">VivaSpeak para despachos legales</p>
      <h1 class="hero-title">
        Filtra llamadas legales y dedica tu tiempo solo a los casos que merecen la pena.
      </h1>
      <p class="hero-subtitle">
        Recoge información clave y envía un resumen listo para decidir. 24/7, multidioma y con aviso
        de grabación integrado.
      </p>
      <div class="hero-points">
        <p>
          <Icon name="circle-check" size={16} /> Nombre, teléfono y email siempre capturados.
        </p>
        <p>
          <Icon name="circle-check" size={16} /> Motivo, urgencia y jurisdicción en segundos.
        </p>
        <p><Icon name="circle-check" size={16} /> Transcripción y audio por email.</p>
      </div>
      <div class="hero-actions">
        <a href="#cta-final" class="btn btn-primary">Agendar demo</a>
        <a href="#flow" class="btn btn-secondary">Cómo funciona</a>
      </div>
    </div>
    <div class="hero-panel">
      <div class="panel-header">
        <p class="panel-eyebrow">Lo que te llega sin interrumpir tu trabajo</p>
        <div class="panel-badges">
          <span class="badge">Resumen estructurado</span>
          <span class="badge">Datos del cliente</span>
          <span class="badge">Prioridad definida</span>
        </div>
      </div>
      <div class="card">
        <div
          style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2);"
        >
          <span class="badge" style="background: rgba(212, 169, 90, 0.2); color: var(--gray-900);"
            >Urgente</span
          >
          <span style="font-size: var(--text-xs); color: var(--color-text-muted);">Hace 2 min</span>
        </div>
        <h3>Consulta de arrendamientos</h3>
        <p>Solicita revisión de contrato. Necesita respuesta esta semana.</p>
        <div
          style="display: grid; gap: var(--space-1); margin-top: var(--space-3); font-size: var(--text-sm); color: var(--color-text-muted);"
        >
          <span><Icon name="user" size={14} /> Marta R.</span>
          <span><Icon name="phone" size={14} /> +34 6XX XXX XXX</span>
          <span><Icon name="scale-balanced" size={14} /> Civil</span>
        </div>
      </div>
      <div class="card" style="opacity: 0.7;">
        <div
          style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2);"
        >
          <span class="badge">Informativa</span>
          <span style="font-size: var(--text-xs); color: var(--color-text-muted);">Ayer</span>
        </div>
        <h3>Reclamación de deuda</h3>
        <p>Consulta inicial. Espera presupuesto y siguientes pasos.</p>
      </div>
    </div>
  </div>
</section>

<!-- COMPLIANCE -->
<section class="section" style="background: var(--color-bg-subtle);">
  <div class="container">
    <div class="compliance-card">
      <div>
        <h2 style="margin: 0 0 var(--space-2);">Aviso legal desde el primer segundo</h2>
        <p style="margin: 0; color: var(--color-text-muted);">
          La agente informa automáticamente de la grabación y transcripción, ayudándote a cumplir
          RGPD y normativa española de grabación de llamadas.
        </p>
      </div>
      <div class="compliance-pill">
        <Icon name="shield-halved" size={18} />
        Aviso legal integrado
      </div>
    </div>
  </div>
</section>

<!-- PAIN -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">El problema diario</p>
      <h2>Llamadas constantes, urgencias mezcladas y cero tiempo</h2>
      <p>
        Un despacho vive del tiempo. Cuando suena el teléfono, se corta el trabajo, se pierden casos
        y se acumula el backoffice.
      </p>
    </div>
    <div class="grid grid-3">
      <div class="card">
        <h3>Interrupciones continuas</h3>
        <p>El agente atiende y registra datos para que no interrumpa tu trabajo.</p>
      </div>
      <div class="card">
        <h3>Casos sin filtro ni prioridad</h3>
        <p>Clasifica por especialidad y urgencia para que respondas en el orden correcto.</p>
      </div>
      <div class="card">
        <h3>Urgencias reales mezcladas con consultas sin valor</h3>
        <p>Separa lo urgente de lo accesorio para que no se te escape un plazo crítico.</p>
      </div>
    </div>
  </div>
</section>

<!-- FLOW -->
<section id="flow" class="section" style="background: var(--color-bg);">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Flujo legal</p>
      <h2>Un filtro claro antes de que entres en la llamada</h2>
    </div>
    <div class="workflow">
      <div class="workflow-step">
        <span>01</span>
        <div>
          <h4>Identifica y clasifica</h4>
          <p>Detecta área legal, urgencia y expectativa del cliente.</p>
        </div>
      </div>
      <div class="workflow-step">
        <span>02</span>
        <div>
          <h4>Pregunta lo imprescindible</h4>
          <p>Recoge datos y hace las preguntas que tu despacho define.</p>
        </div>
      </div>
      <div class="workflow-step">
        <span>03</span>
        <div>
          <h4>Te llega todo resumido</h4>
          <p>Resumen claro por email y en el panel con historial completo.</p>
        </div>
      </div>
    </div>
    <p
      style="margin-top: var(--space-6); text-align: center; font-weight: var(--font-semibold); color: var(--color-text-muted);"
    >
      Tú defines las preguntas. El agente solo ejecuta.
    </p>
  </div>
</section>

<!-- BENEFITS -->
<section class="section" style="background: var(--color-bg-subtle);">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Lo que recibes</p>
      <h2>Información lista para decidir en segundos</h2>
    </div>
    <div class="grid grid-4">
      <div class="card">
        <h3>Resumen ejecutivo</h3>
        <p>Motivo de consulta, urgencia y prioridad marcados.</p>
      </div>
      <div class="card">
        <h3>Motivo legal estructurado</h3>
        <p>Tipo de caso, urgencia y siguiente paso definidos.</p>
      </div>
      <div class="card">
        <h3>Transcripción y audio</h3>
        <p>Todo queda registrado para revisar o delegar.</p>
      </div>
      <div class="card">
        <h3>Multidioma</h3>
        <p>Español, inglés y alemán para clientes internacionales.</p>
      </div>
    </div>
  </div>
</section>

<!-- USE CASES -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <p class="eyebrow">Casos de uso</p>
      <h2>Tu recepción telefónica legal, siempre activa</h2>
    </div>
    <div class="grid grid-4">
      <div class="card">
        <h3>Filtro de viabilidad</h3>
        <p>El agente detecta si el caso entra en tu especialidad y rango.</p>
      </div>
      <div class="card">
        <h3>Prioridad por urgencia</h3>
        <p>Identifica plazos críticos para que nadie pierda una fecha.</p>
      </div>
      <div class="card">
        <h3>Consultas repetitivas</h3>
        <p>Responde dudas básicas sin ocupar a tu equipo.</p>
      </div>
      <div class="card">
        <h3>Derivación inteligente</h3>
        <p>Clasifica por área y envíalo al abogado correcto.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section id="cta-final" class="section">
  <div class="container">
    <div class="cta-panel">
      <div>
        <p class="eyebrow">Prueba VivaSpeak</p>
        <h2 style="margin: var(--space-3) 0;">Activa tu agente legal en 24 horas</h2>
        <p style="color: var(--color-text-muted); margin: 0;">
          Cuéntanos tu especialidad y configuramos el flujo de llamadas.
        </p>
        <p style="color: var(--color-text-muted); margin: var(--space-2) 0 0;">
          Sin permanencia. Ajustes incluidos.
        </p>
      </div>
      <div class="cta-actions">
        <a href="https://calendly.com/vivaspeak/30min" class="btn btn-primary">Agendar demo</a>
      </div>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container">
    <div class="section-header text-center">
      <h2>Preguntas frecuentes</h2>
    </div>
    <div class="faq-grid">
      <details class="faq-card">
        <summary>¿Se puede personalizar por especialidad?</summary>
        <p>
          Sí, 100%. Definimos preguntas, criterios de descarte y orden del flujo según tu
          especialidad.
        </p>
      </details>
      <details class="faq-card">
        <summary>¿Graba llamadas?</summary>
        <p>Sí, con aviso legal automático desde el primer segundo.</p>
      </details>
      <details class="faq-card">
        <summary>¿En cuánto tiempo está listo?</summary>
        <p>24 horas desde que recibimos tu contexto.</p>
      </details>
      <details class="faq-card">
        <summary>¿Cumple RGPD y normativa de grabación en España?</summary>
        <p>
          Sí. Incluye aviso legal automático al inicio de la llamada y se adapta a la normativa de
          grabación en España.
        </p>
      </details>
    </div>
  </div>
</section>

<Footer />

<style>
  /* Gold accent overrides for law landing */
  .law-landing {
    --law-gold: #d4a95a;
    --law-gold-dark: #b8873d;
  }

  .law-hero {
    background: radial-gradient(circle at top, #2f3c57 0%, #1b1f2a 55%, #151923 100%);
    color: #fdfbf7;
    padding: calc(var(--space-24) + var(--space-10)) 0 var(--space-20);
  }

  .law-hero .hero-title {
    color: #fdfbf7;
  }

  .law-hero .hero-subtitle {
    color: rgba(255, 255, 255, 0.8);
  }

  .law-hero .hero-panel {
    background: rgba(253, 251, 247, 0.06);
    border-color: rgba(253, 251, 247, 0.16);
    box-shadow: 0 24px 60px rgba(9, 12, 18, 0.35);
    backdrop-filter: blur(6px);
  }

  .law-hero .hero-panel .card {
    background: #ffffff;
    color: var(--gray-900);
  }

  .law-eyebrow {
    background: rgba(212, 169, 90, 0.18);
    color: #fdfbf7;
  }

  .hero-points {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .hero-points p {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.85);
  }

  .hero-points .icon {
    color: var(--law-gold);
  }

  .panel-header {
    display: grid;
    gap: var(--space-4);
  }

  .panel-eyebrow {
    margin: 0;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(253, 251, 247, 0.75);
  }

  .panel-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .law-hero .panel-badges .badge {
    background: rgba(253, 251, 247, 0.12);
    border: 1px solid rgba(253, 251, 247, 0.2);
    color: rgba(253, 251, 247, 0.8);
  }

  .law-hero .btn-secondary {
    border-color: rgba(255, 255, 255, 0.55);
    color: rgba(255, 255, 255, 0.85);
  }

  .law-hero .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.8);
    color: #fdfbf7;
    background: transparent;
  }
</style>
