---
import '../../styles/header.css';

const { lang = 'es' } = Astro.props;
const isEn = lang === 'en';
const defaultBase = isEn ? '/en/' : '/';

const {
  ctaLabel = isEn ? 'Request a demo' : 'Solicitar demo',
  ctaHref = '#cta-final',
  secondaryLabel = isEn ? 'Back to VivaSpeak' : 'Volver a VivaSpeak',
  secondaryHref = defaultBase,
} = Astro.props;
---

<header class="site-header site-header--landing">
  <div class="header-container">
    <div class="header-brand">
      <a href={isEn ? secondaryHref : '/'} aria-label={isEn ? 'Go to VivaSpeak' : 'Ir a VivaSpeak'}>
        <img
          src="/assets/Logo transparente cropped.png"
          alt={isEn ? 'VivaSpeak logo' : 'Logotipo de VivaSpeak'}
          loading="eager"
        />
      </a>
    </div>

    <nav class="desktop-nav" aria-label={isEn ? 'Landing navigation' : 'Navegación de landing'}>
      <ul class="nav-list">
        <li class="landing-secondary-link"><a href={secondaryHref}>{secondaryLabel}</a></li>
        <li class="nav-cta"><a href={ctaHref}>{ctaLabel}</a></li>
      </ul>
    </nav>
  </div>
</header>
