---
import '../../styles/landing-header.css';

const { lang = 'es' } = Astro.props;
const isEn = lang === 'en';
const defaultBase = isEn ? '/en/' : '/';

const {
  ctaLabel = isEn ? 'Request a demo' : 'Solicitar demo',
  ctaHref = '#cta-final',
  secondaryLabel = isEn ? 'Back to VivaSpeak' : 'Volver a VivaSpeak',
  secondaryHref = defaultBase,
} = Astro.props;
---

<header class="landing-header">
  <div class="landing-header__container">
    <a class="landing-header__brand" href={isEn ? secondaryHref : '/'} aria-label={isEn ? 'Go to VivaSpeak' : 'Ir a VivaSpeak'}>
      <img
        src="/assets/Logo transparente cropped.png"
        alt={isEn ? 'VivaSpeak logo' : 'Logotipo de VivaSpeak'}
        loading="eager"
      />
    </a>
    <div class="landing-header__actions">
      <a class="landing-header__link" href={secondaryHref}>{secondaryLabel}</a>
      <a class="btn-primary landing-header__cta" href={ctaHref}>{ctaLabel}</a>
    </div>
  </div>
</header>
